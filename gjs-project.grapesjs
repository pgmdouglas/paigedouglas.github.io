"type":"text","attributes":{"id":"irevsubtitle"},"components":[{"type":"textnode","content":"Feedback from clients and colleagues who have experienced working with me on various projects."}]}]},{"type":"flex-row","classes":["gjs-plg-flex-row"],"attributes":{"data-type-role":"flex-row","id":"irevcards"},"components":[{"type":"flex-column","classes":["gjs-plg-flex-column"],"attributes":{"data-type-role":"flex-column","id":"irev1"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://cdn.grapesjs.com/workspaces/cmf55fvd721dbd80a2yd22yfh/assets/0343c746-3d70-4c5a-869e-d047d6900ab8__asset-testimony-avatar-10.webp","alt":"Client Photo","id":"irev1img"}},{"tagName":"p","type":"text","attributes":{"id":"irev1text"},"components":[{"type":"textnode","content":"Working with Alex was an absolute pleasure. Their attention to detail and creative vision transformed our website into a powerful marketing tool. The results exceeded our expectations and our conversion rates have increased significantly."}]},{"tagName":"h3","type":"heading","attributes":{"id":"irev1name"},"components":[{"type":"textnode","content":"Jessica Thompson"}]},{"tagName":"span","type":"text","attributes":{"id":"irev1role"},"components":[{"type":"textnode","content":"Marketing Director"}]}]},{"type":"flex-column","classes":["gjs-plg-flex-column"],"attributes":{"data-type-role":"flex-column","id":"irev2"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://cdn.grapesjs.com/workspaces/cmf55fvd721dbd80a2yd22yfh/assets/39989f95-1938-471c-b139-f4be654be3c6__asset-testimony-avatar-13.webp","alt":"Client Photo","id":"irev2img"}},{"tagName":"p","type":"text","attributes":{"id":"irev2text"},"components":[{"type":"textnode","content":"An exceptional designer with the technical skills to back it up. Alex delivered our project on time and on budget, while maintaining the highest quality standards. I highly recommend their services to anyone looking for top-tier design work."}]},{"tagName":"h3","type":"heading","attributes":{"id":"irev2name"},"components":[{"type":"textnode","content":"Marcus Chen"}]},{"tagName":"span","type":"text","attributes":{"id":"irev2role"},"components":[{"type":"textnode","content":"Product Manager"}]}]},{"type":"flex-column","classes":["gjs-plg-flex-column"],"attributes":{"data-type-role":"flex-column","id":"irev3"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://cdn.grapesjs.com/workspaces/cmf55fvd721dbd80a2yd22yfh/assets/a21b5c54-9faa-464e-bc33-5366290e0d52__asset-testimony-avatar-18.webp","alt":"Client Photo","id":"irev3img"}},{"tagName":"p","type":"text","attributes":{"id":"irev3text"},"components":[{"type":"textnode","content":"Professional, creative, and reliable. Alex took the time to understand our brand and created a visual identity that perfectly captures who we are. The collaboration was smooth and the final product speaks for itself."}]},{"tagName":"h3","type":"heading","attributes":{"id":"irev3name"},"components":[{"type":"textnode","content":"Sarah Anderson"}]},{"tagName":"span","type":"text","attributes":{"id":"irev3role"},"components":[{"type":"textnode","content":"Business Owner"}]}]}],"snap":"","snap-divisions":12}]}]},{"type":"section","classes":["gjs-section"],"attributes":{"id":"events"},"components":[{"type":"container","classes":["gjs-container"],"attributes":{"id":"iblogcnt"},"components":[{"type":"flex-column","classes":["gjs-plg-flex-column"],"attributes":{"data-type-role":"flex-column","id":"iblogheader"},"components":[{"tagName":"h2","type":"heading","attributes":{"id":"iblogtitle"},"components":[{"type":"textnode","content":"Upcoming Events"}]}]},{"type":"flex-row","classes":["gjs-plg-flex-row"],"attributes":{"data-type-role":"flex-row","id":"iblogcards"},"components":[{"type":"flex-column","classes":["gjs-plg-flex-column"],"attributes":{"data-type-role":"flex-column","id":"iblog1"},"components":[{"type":"image","re